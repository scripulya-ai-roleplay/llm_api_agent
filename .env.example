# --- RabbitMQ ---
RABBIT_URL=amqp://guest:guest@rabbitmq:5672/
LLM_REQUEST_QUEUE=llm.agent.request
LLM_RESULT_QUEUE=llm.agent.result

# --- Provider API keys (empty = provider disabled, service still boots) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Generation defaults ---
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Shared system prompt; backend may override per-message later.
SYSTEM_PROMPT=You are a helpful assistant.

DEBUG=false
